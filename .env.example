# NVIDIA NIM 配置
NVIDIA_NIM_API_KEY=""


# OpenRouter 配置
OPENROUTER_API_KEY=""


# DeepSeek 配置（使用 api.deepseek.com/anthropic 的原生 Anthropic Messages 接口）
DEEPSEEK_API_KEY=""


# MiniMax 配置（官方 API key；默认 OpenAI 兼容接口）
MINIMAX_API_KEY=""
MINIMAX_BASE_URL="https://api.minimax.chat/v1"


# Kimi（Moonshot OpenAI 兼容 API）
KIMI_API_KEY=""


# LM Studio 配置（本地 provider，无需 API key）
LM_STUDIO_BASE_URL="http://localhost:1234/v1"


# Llama.cpp 配置（本地 provider，无需 API key）
LLAMACPP_BASE_URL="http://localhost:8080/v1"


# Ollama 配置（本地 provider，无需 API key）
OLLAMA_BASE_URL="http://localhost:11434"


# 所有 Claude 模型请求都会映射到这里配置的模型，MODEL 为兜底值
# 格式：provider_type/model/name
# 可用 provider："nvidia_nim" | "open_router" | "deepseek" | "kimi" | "minimax" | "lmstudio" | "llamacpp" | "ollama"
MODEL_OPUS=
MODEL_SONNET=
MODEL_HAIKU=
MODEL="nvidia_nim/z-ai/glm4.7"


# 可选的 live smoke 模型覆盖。即使 MODEL/MODEL_* 路由到其他 provider，
# 只要某个 provider 被配置，provider smoke 也会按该 provider 单独跑一次。
FCC_SMOKE_MODEL_NVIDIA_NIM=
FCC_SMOKE_MODEL_OPEN_ROUTER=
FCC_SMOKE_MODEL_DEEPSEEK=
FCC_SMOKE_MODEL_LMSTUDIO=
FCC_SMOKE_MODEL_LLAMACPP=
FCC_SMOKE_MODEL_OLLAMA=
FCC_SMOKE_MODEL_KIMI=
FCC_SMOKE_MODEL_MINIMAX=


# Thinking 输出
# 按 Claude 模型粒度控制 provider reasoning 请求和 Claude thinking block。
# 某个模型开关留空时，会继承 ENABLE_MODEL_THINKING。
ENABLE_OPUS_THINKING=
ENABLE_SONNET_THINKING=
ENABLE_HAIKU_THINKING=
ENABLE_MODEL_THINKING=true


# Provider 配置
# 每个 provider 支持独立代理：http 和 socks5，例如："http://username:password@host:port"
NVIDIA_NIM_PROXY=""
OPENROUTER_PROXY=""
MINIMAX_PROXY=""
LMSTUDIO_PROXY=""
LLAMACPP_PROXY=""
KIMI_PROXY=""

PROVIDER_RATE_LIMIT=1
PROVIDER_RATE_WINDOW=3
PROVIDER_MAX_CONCURRENCY=5


# provider API 请求使用的 HTTP 客户端超时（秒）
HTTP_READ_TIMEOUT=300
HTTP_WRITE_TIMEOUT=60
HTTP_CONNECT_TIMEOUT=60


# 可选服务端 API key（Anthropic 风格）
ANTHROPIC_AUTH_TOKEN="freecc"


# 消息平台："telegram" | "discord" | "none"
MESSAGING_PLATFORM="discord"
MESSAGING_RATE_LIMIT=1
MESSAGING_RATE_WINDOW=1


# 语音消息转写
VOICE_NOTE_ENABLED=false
# WHISPER_DEVICE："cpu" | "cuda" | "nvidia_nim"
# - "cpu"/"cuda"：使用 Hugging Face transformers Whisper（离线、免费；安装：uv sync --extra voice_local）
# - "nvidia_nim"：通过 Riva gRPC 使用 NVIDIA NIM Whisper（需要 NVIDIA_NIM_API_KEY；安装：uv sync --extra voice）
# （与 MODEL=nvidia_nim/... 无关：MODEL 选择的是聊天 provider；这里仅控制语音 STT。）
WHISPER_DEVICE="nvidia_nim"
# WHISPER_MODEL：
# - cpu/cuda：Hugging Face 模型 ID 或短名（tiny、base、small、medium、large-v2、large-v3、large-v3-turbo）
# - nvidia_nim：NVIDIA NIM 模型（例如："nvidia/parakeet-ctc-1.1b-asr"、"openai/whisper-large-v3"）
# - 对 nvidia_nim，默认建议用 "openai/whisper-large-v3" 以获得更好效果
WHISPER_MODEL="openai/whisper-large-v3"
HF_TOKEN=""


# Telegram 配置
TELEGRAM_BOT_TOKEN=""
ALLOWED_TELEGRAM_USER_ID=""


# Discord 配置
DISCORD_BOT_TOKEN=""
ALLOWED_DISCORD_CHANNELS=""


# Agent 配置
CLAUDE_WORKSPACE="./agent_workspace"
ALLOWED_DIR=""
CLAUDE_CLI_BIN="claude"
FAST_PREFIX_DETECTION=true
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true


# 本地 Anthropic web_search / web_fetch 处理（会发起对外 HTTP，默认开启）
ENABLE_WEB_SERVER_TOOLS=true
WEB_FETCH_ALLOWED_SCHEMES=http,https
WEB_FETCH_ALLOW_PRIVATE_NETWORKS=false


# 详细诊断日志（生产环境避免记录原始 prompts / SSE body）
DEBUG_PLATFORM_EDITS=false
DEBUG_SUBAGENT_STACK=false
# 为 true 时，还会放开 DEBUG 级 httpx/httpcore/telegram 噪声日志（不只是 payload 日志）。
LOG_RAW_API_PAYLOADS=false
LOG_RAW_SSE_EVENTS=false
# 为 true 时，未处理错误会记录完整异常文本和 traceback（可能泄露请求相关数据）。
LOG_API_ERROR_TRACEBACKS=false
# 为 true 时，在 messaging 适配器中记录消息/转写文本预览（可能泄露用户内容）。
LOG_RAW_MESSAGING_CONTENT=false
# 为 true 时，记录完整 Claude CLI stderr、非 JSON stdout 行和解析错误文本。
LOG_RAW_CLI_DIAGNOSTICS=false
# 为 true 时，在 messaging 中记录完整异常与 CLI 错误信息字符串（可能泄露用户内容）。
LOG_MESSAGING_ERROR_DETAILS=false
